# === Supabase ===
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>

# === Credenciais do usuário admin (para login via email/password) ===
SUPABASE_EMAIL=
SUPABASE_PASSWORD=

# === Configuração de importação ===
# Caminho da pasta raiz (passado via CLI também — este é fallback default)
IMPORT_ROOT_PATH=/Users/allan/003_ALMIR_FERRAGENS/HOME_CENTER

# Concorrência: quantos uploads SPED em paralelo (R5 do backend limita a 3)
SPED_CONCURRENCY=1

# Concorrência: quantas chamadas process_single_xml em paralelo
XML_CONCURRENCY=3

# Gap entre uploads SPED (ms)
SPED_GAP_MS=2000

# Cooldown inicial antes do primeiro SPED (ms) — gateway Supabase pode precisar esfriar
SPED_COOLDOWN_MS=30000

# Deadline total por arquivo (ms) — abandona e recoloca na fila se exceder
SPED_DEADLINE_MS=600000
